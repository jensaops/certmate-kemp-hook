# kemp.yml — Kemp LoadMaster targets for CertMate deploy hook
#
# Place at /etc/certmate/kemp.yml
# Override path with: KEMP_CONFIG=/path/to/kemp.yml
#
# All certificates issued or renewed by CertMate are uploaded to every
# Kemp entry listed here. No domain filtering — the hook uploads everything.
#
# On first upload: cert is added to Kemp (replace=0). Bind it to a
# Virtual Service manually in the Kemp UI.
#
# On renewal: cert is replaced (replace=1). Kemp automatically updates
# all existing VS bindings using that alias.
#
# Credentials are resolved from per-host .env files:
#   /etc/certmate/kemp.d/<hostname>.env
#
# Basic auth example (/etc/certmate/kemp.d/kemp1.example.com.env):
#   KEMP_USER=admin
#   KEMP_PASS=yourpassword
#
# API key auth example:
#   KEMP_APIKEY=your-api-key
#
# Fields:
#   url         (required) Base URL of the Kemp REST API
#   cert_alias  (optional) Override the auto-derived alias
#               Default alias: domain with dots replaced by dashes
#               e.g. test3.primeoperator.com -> test3-primeoperator-com

- url: https://kemp1.example.com

# Multiple Kemps — all get every cert
# - url: https://kemp2.example.com

# With alias override
# - url: https://kemp3.example.com
#   cert_alias: my-custom-alias
