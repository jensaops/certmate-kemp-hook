# /etc/certmate/kemp.d/kemp1.example.com.env
# Per-host credentials for the Kemp deploy hook.
# Filename must match the hostname in the Kemp URL exactly.
# Permissions should be 600 (readable by the CertMate process only).
#
# chmod 600 /etc/certmate/kemp.d/kemp1.example.com.env

KEMP_USER=admin
KEMP_PASS=your-password-here

# Optional: override upload mode for this host only (new | replace)
# KEMP_MODE=replace
